# Application
APP_NAME=Airport AI Platform
APP_ENV=development
DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:////app/data/sqlite/airport.db

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# RAG
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# Paths
PDF_STORAGE_PATH=/app/data/pdfs
FAISS_INDEX_PATH=/app/data/faiss
LOG_PATH=/app/data/logs

# SQL Agent
SQL_MAX_ROWS=100

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
